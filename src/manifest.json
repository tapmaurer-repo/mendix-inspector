{
  "manifest_version": 3,
  "name": "MxInspector",
  "description": "Mendix Page Inspector & Debugger - Analyze performance, accessibility, security, and more. React client support!",
  "version": "1.3.0",
  "author": "Tim Maurer",
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "MxInspector - Click to Inspect"
  },
  
  "permissions": [
    "activeTab",
    "scripting"
  ],
  
  "host_permissions": [
    "<all_urls>"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/perf-tracker.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/mx-data-extractor.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  
  "web_accessible_resources": [
    {
      "resources": ["content/inspector.js", "content/mx-data-extractor.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
